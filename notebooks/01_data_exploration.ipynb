   "source": [
    "import os\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "data_dir = \"data/train\"\n",
    "files = os.listdir(data_dir)[:10]\n",
    "for f in files:\n",
    "    img = cv2.imread(os.path.join(data_dir,f),0)\n",
    "    plt.imshow(img, cmap=\"gray\")\n",
    "    plt.title(f)\n",
    "    plt.show()"
   ],
